MONITOR_ENV_NAME=test
MONITOR_POLL_INTERVAL_SECONDS=1
MONITOR_FAILURE_RETRY_INTERVAL_SECONDS=1
MONITOR_FAILURE_THRESHOLD_ATTEMPTS=5
MONITOR_REMINDER_INTERVAL_SECONDS=10
MONITOR_REDIS_URL=redis://localhost:6379/15
MONITOR_REDIS_KEY_PREFIX=selfhost_monitor_test
MONITOR_SMTP_HOST=localhost
MONITOR_SMTP_PORT=1025
MONITOR_SMTP_STARTTLS=false
MONITOR_SMTP_USERNAME=test-user
MONITOR_SMTP_PASSWORD=test-password
