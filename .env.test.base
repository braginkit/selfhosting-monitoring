MONITOR_SMTP_TO=owner@example.local
MONITOR_MATRIX_HOMESERVER=https://matrix.test.local
MONITOR_MATRIX_USER_ID=@monitorbot:matrix.test.local
MONITOR_MATRIX_ACCESS_TOKEN=test-token
MONITOR_MATRIX_ROOM_ID=!testroom:matrix.test.local
MONITOR_TARGETS_FILE=tests/fixtures/targets.test.yml
MONITOR_SMTP_DELIVERY_TRACKING_ENABLED=false
