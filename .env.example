MONITOR_ENV_NAME=production
MONITOR_POLL_INTERVAL_SECONDS=60
MONITOR_FAILURE_RETRY_INTERVAL_SECONDS=60
MONITOR_FAILURE_THRESHOLD_ATTEMPTS=5
MONITOR_REMINDER_INTERVAL_SECONDS=28800
MONITOR_REDIS_URL=redis://redis:6379/0
MONITOR_REDIS_KEY_PREFIX=selfhost_monitor
MONITOR_IMAGE=ghcr.io/braginkit/selfhosting-monitoring:latest
MONITOR_SMTP_HOST=smtp.example.invalid
MONITOR_SMTP_PORT=587
MONITOR_SMTP_STARTTLS=true
MONITOR_SMTP_USERNAME=monitor@example.invalid
MONITOR_SMTP_PASSWORD=CHANGE_ME
MONITOR_SMTP_FROM=monitor@example.invalid
MONITOR_SMTP_TO=owner@example.invalid
MONITOR_MATRIX_HOMESERVER=https://matrix.example.invalid
MONITOR_MATRIX_USER_ID=@monitorbot:matrix.example.invalid
MONITOR_MATRIX_ACCESS_TOKEN=CHANGE_ME
MONITOR_MATRIX_ROOM_ID=!CHANGE_ME:matrix.example.invalid
MONITOR_ALERT_CHANNEL_PRIORITY=smtp,matrix_outbox
MONITOR_TARGETS_FILE=targets.yml
