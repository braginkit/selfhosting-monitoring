# Production env for ~/monitoring on the host (copy to .env and fill CHANGE_ME).
# Merge with .env.base in docker-compose; secrets only in .env (gitignored).

MONITOR_ENV_NAME=production
MONITOR_POLL_INTERVAL_SECONDS=60
MONITOR_FAILURE_RETRY_INTERVAL_SECONDS=60
MONITOR_FAILURE_THRESHOLD_ATTEMPTS=5
MONITOR_REMINDER_INTERVAL_SECONDS=28800

MONITOR_REDIS_URL=redis://redis:6379/0
MONITOR_REDIS_KEY_PREFIX=selfhost_monitor

MONITOR_SMTP_HOST=mail.bragin.crazedns.ru
MONITOR_SMTP_PORT=587
MONITOR_SMTP_STARTTLS=true
# SMTP auth: mailbox on mailserver (e.g. monitoring@bragin.crazedns.ru).
MONITOR_SMTP_USERNAME=CHANGE_ME
MONITOR_SMTP_PASSWORD=CHANGE_ME
# From/To: addresses allowed by your mail relay (iCloud relay needs an iCloud-owned From).
MONITOR_SMTP_FROM=CHANGE_ME
MONITOR_SMTP_TO=CHANGE_ME

MONITOR_MATRIX_HOMESERVER=https://matrix.bragin.crazedns.ru
MONITOR_MATRIX_USER_ID=CHANGE_ME
MONITOR_MATRIX_ACCESS_TOKEN=CHANGE_ME
MONITOR_MATRIX_ROOM_ID=CHANGE_ME

MONITOR_ALERT_CHANNEL_PRIORITY=smtp,matrix_outbox
MONITOR_TARGETS_FILE=targets.yml

MONITOR_SMTP_DELIVERY_TRACKING_ENABLED=true
MONITOR_SMTP_DELIVERY_GRACE_SECONDS=120
MONITOR_SMTP_DELIVERY_TIMEOUT_SECONDS=600
MONITOR_MAIL_LOG_DIR=/var/log/mail
