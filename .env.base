MONITOR_SMTP_HOST=
MONITOR_SMTP_PORT=
MONITOR_SMTP_STARTTLS=
MONITOR_SMTP_USERNAME=
MONITOR_SMTP_PASSWORD=
MONITOR_SMTP_FROM=
MONITOR_SMTP_TO=
MONITOR_MATRIX_HOMESERVER=
MONITOR_MATRIX_USER_ID=
MONITOR_MATRIX_ACCESS_TOKEN=
MONITOR_MATRIX_ROOM_ID=
